# Copy this file to .env and fill in values

# OpenAI API Key for LLM-enhanced recommendations (optional)
# If the key is empty, the system falls back to the algorithm-only results
# OPENAI_API_KEY=

# DeepSeek API Key for two-LLM exercise recommendations (optional)
# Used for the /api/recommendations/deepseek endpoint
# DEEPSEEK_API_KEY=

# Passcode for patient access control
PHYSIO_PASSCODE=physio2024
